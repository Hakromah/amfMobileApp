{
  "expo": {
    "name": "mobileapp",
    "slug": "mobileapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/fofana.png",
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/fofana.png",
        "backgroundColor": "#E6F4FE"
      },
      "package": "com.amfexpo.mobileapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/fofana.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/fofana.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "43b1a9ff-572b-4143-9d69-c64832cf5382"
      }
    }
  }
}
